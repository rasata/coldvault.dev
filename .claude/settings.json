{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(git -C target log:*)",
      "Bash(git -C target diff:*)",
      "Bash(git -C target show:*)",
      "Bash(git -C target blame:*)",
      "Bash(git -C target status:*)",
      "Bash(git -C target ls-files:*)",
      "Bash(git submodule status:*)",
      "Bash(semgrep:*)",
      "Bash(bandit:*)",
      "Bash(gosec:*)",
      "Bash(staticcheck:*)",
      "Bash(govulncheck:*)",
      "Bash(cppcheck:*)",
      "Bash(flawfinder:*)",
      "Bash(shellcheck:*)",
      "Bash(njsscan:*)",
      "Bash(retire:*)",
      "Bash(eslint:*)",
      "Bash(brakeman:*)",
      "Bash(psalm:*)",
      "Bash(phpstan:*)",
      "Bash(bundler-audit:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo-audit:*)",
      "Bash(cargo deny:*)",
      "Bash(gitleaks:*)",
      "Bash(trufflehog:*)",
      "Bash(detect-secrets:*)",
      "Bash(ggshield:*)",
      "Bash(osv-scanner:*)",
      "Bash(trivy:*)",
      "Bash(grype:*)",
      "Bash(syft:*)",
      "Bash(dependency-check:*)",
      "Bash(pip-audit:*)",
      "Bash(safety:*)",
      "Bash(snyk test:*)",
      "Bash(snyk code:*)",
      "Bash(yara:*)",
      "Bash(capa:*)",
      "Bash(clamscan:*)",
      "Bash(olevba:*)",
      "Bash(binwalk:*)",
      "Bash(tfsec:*)",
      "Bash(terrascan:*)",
      "Bash(checkov:*)",
      "Bash(hadolint:*)",
      "Bash(dockle:*)",
      "Bash(kubesec:*)",
      "Bash(kube-score:*)",
      "Bash(actionlint:*)",
      "Bash(zizmor:*)",
      "Bash(bash scripts/scan-secrets.sh:*)",
      "Bash(bash scripts/scan-deps.sh:*)",
      "Bash(bash scripts/scan-sast.sh:*)",
      "Bash(bash scripts/scan-malware.sh:*)",
      "Bash(bash scripts/scan-iac.sh:*)",
      "Bash(bash scripts/audit-all.sh:*)",
      "Bash(mkdir -p reports)",
      "Bash(mkdir -p reports/*)"
    ],
    "deny": [
      "Bash(cd target*)",
      "Bash(*npm install*)",
      "Bash(*npm ci*)",
      "Bash(*npm run*)",
      "Bash(*npm start*)",
      "Bash(*npm test*)",
      "Bash(*npm exec*)",
      "Bash(*npx *)",
      "Bash(*yarn install*)",
      "Bash(*yarn *)",
      "Bash(*pnpm install*)",
      "Bash(*pnpm *)",
      "Bash(*pip install*)",
      "Bash(*pip3 install*)",
      "Bash(*pipx install target*)",
      "Bash(*poetry install*)",
      "Bash(*poetry run*)",
      "Bash(*uv pip install*)",
      "Bash(*cargo build*)",
      "Bash(*cargo run*)",
      "Bash(*cargo test*)",
      "Bash(*go build*)",
      "Bash(*go run*)",
      "Bash(*go test*)",
      "Bash(*go install*)",
      "Bash(*mvn *)",
      "Bash(*gradle *)",
      "Bash(*make *)",
      "Bash(*cmake *)",
      "Bash(*composer install*)",
      "Bash(*composer update*)",
      "Bash(*bundle install*)",
      "Bash(*bundle exec*)",
      "Bash(*gem install*)",
      "Bash(*docker build target*)",
      "Bash(*docker run*)",
      "Bash(node target/*)",
      "Bash(python target/*)",
      "Bash(python3 target/*)",
      "Bash(ruby target/*)",
      "Bash(php target/*)",
      "Bash(bash target/*)",
      "Bash(sh target/*)",
      "Bash(./target/*)",
      "Bash(source target/*)",
      "Bash(. target/*)",
      "Bash(*curl *|*sh*)",
      "Bash(*wget *|*sh*)",
      "Write(target/**)",
      "Edit(target/**)"
    ]
  },
  "env": {
    "AUDIT_HOME": "/workspaces",
    "TARGET_DIR": "target",
    "SEMGREP_RULES_DIR": "/opt/semgrep-rules",
    "YARA_RULES_DIR": "/opt/yara-rules"
  }
}
